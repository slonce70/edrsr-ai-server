# ============================================
# EDRSR-AI Server Environment Configuration
# ============================================

# === AI Configuration ===
# Gemini API Key - отримайте безплатно у Google AI Studio: https://ai.google.dev

# Один ключ (backward compatible):
GEMINI_API_KEY=

# АБО кілька ключів через кому для збільшення лімітів (пріоритет над GEMINI_API_KEY):
# 6 ключів = 60 RPM (Flash) замість 10 RPM на безплатному тарифі
GEMINI_API_KEYS=

# Основна модель (Flash швидша, Pro розумніша)
MODEL_NAME=gemini-2.5-flash
# Fallback модель при rate limit основної
FALLBACK_MODEL_NAME=gemini-2.5-pro

# Generation parameters
TEMPERATURE=0.3
TOP_K=40
TOP_P=0.8
MAX_TOKENS=65536
MAX_TOKENS_PER_BATCH=60000

# Rate-limit backoff (ms)
GEMINI_RATE_LIMIT_COOLDOWN_MS_DEFAULT=60000
GEMINI_RATE_LIMIT_COOLDOWN_MS_FLASH=60000
GEMINI_RATE_LIMIT_COOLDOWN_MS_PRO=90000
GEMINI_RATE_LIMIT_SOFTBAN_MS=180000
GEMINI_RATE_LIMIT_SOFTBAN_THRESHOLD=3

# === CLIProxy (PRIMARY) ===
# Увімкнути CLIProxy як первинний провайдер
ENABLE_CLI_PROXY=false
# URL CLIProxy (OpenAI-сумісний endpoint)
CLI_PROXY_URL=
# Модель для CLIProxy
CLI_PROXY_MODEL=gemini-3-pro-preview(high)
# Токен(и) CLIProxy. Можна один або список через кому/пробіл/крапку з комою.
CLI_PROXY_API_KEY=
CLI_PROXY_API_KEYS=
# Скільки разів пробувати кожен CLIProxy токен перед фолбеком на офіційні ключі
CLI_PROXY_MAX_ATTEMPTS_PER_KEY=1

# === Server Configuration ===
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
UV_THREADPOOL_SIZE=8

# CORS/WS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://__EXTENSION_ID__
WS_ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://__EXTENSION_ID__

# Optional: additionally restrict chrome-extension:// origins by extension ID(s).
# If empty, any chrome extension origin is allowed (backward compatible).
CHROME_EXTENSION_ID=
CHROME_EXTENSION_IDS=

# WebSocket hardening
ENABLE_WS_AUTH_TIMEOUT=true
WS_AUTH_TIMEOUT_MS=10000
ENABLE_WS_CONN_RATE_LIMIT=true
WS_CONN_RATE_WINDOW_MS=60000
WS_CONN_RATE_LIMIT=60

# Public base URL for the web portal (used to build share links)
APP_BASE_URL=https://app.example.com
# Optional override for share link base
PUBLIC_SHARE_BASE_URL=

# === Queue / Status Updates ===
QUEUE_PUMP_INTERVAL_MS=5000
STATUS_UPDATE_INTERVAL_MS=1000
JOBS_MAX_LIMIT=500
SAMPLE_LINKS_LIMIT=200

# === Batch Processing ===
# Розмір batch для завантаження (парсинг)
# Рекомендовано: 10-25 для VPS 1vCPU/2GB, 5-10 для слабких серверів
DOWNLOAD_BATCH_SIZE=10
# Розмір batch для AI (максимум; динамічно ділиться по токенах)
AI_BATCH_SIZE=10
# Legacy: якщо AI_BATCH_SIZE/DOWNLOAD_BATCH_SIZE не задані
BATCH_SIZE=10
# Мінімальна кількість справ для batch обробки (менше = послідовно)
BATCH_THRESHOLD=15
# Затримка між batch запитами (ms)
BATCH_DELAY=1000
# Максимальна кількість паралельних batch-ів AI аналізу
# Рекомендовано: min(кількість_API_ключів, 7)
MAX_CONCURRENT_BATCHES=4

# === Memory Optimization ===
# Максимальний розмір тексту справи (символів) — 0 або порожнє значення означає без обрізання
MAX_CASE_TEXT_LENGTH=0
# Попередження при досягненні порогу пам'яті (MB)
MEMORY_WARNING_MB=200
# Ліміт пам'яті для batch downloading (MB)
MAX_MEMORY_MB=400
MEMORY_LIMIT_MB=500
CRITICAL_MEMORY_MB=420
MAX_OLD_SPACE_MB=1200
MEMORY_CHECK_INTERVAL=30000
ENABLE_MEMORY_MONITORING=true

# === Parsing Optimization ===
# Експериментально: конвертувати HTML в Markdown для LLM
# Зменшує токени на 30-50%, може покращити якість аналізу
USE_MARKDOWN_EXTRACTION=false
# Зберігати повний текст без агресивних перетворень
ENABLE_TEXT_DEDUP=true
ENABLE_TEXT_STRUCTURING=false
ENABLE_TECHNICAL_STRIP=false
STRUCTURE_TEXT_MAX=12000
DEDUPE_MAX_LINE_LENGTH=2000
# TTL для тимчасових помилок кешу (network/timeout), ms. 0 = не застосовувати TTL
TEMP_CACHE_TTL_MS=3600000
# Максимальний розмір HTML для Readability fallback (bytes)
READABILITY_MAX_HTML_BYTES=1500000
# Максимальний розмір HTML для парсингу (bytes)
MAX_HTML_BYTES=3000000
# Scraper safety limits
MAX_SCRIPT_TAGS=200
MAX_HTML_LINE_LENGTH=200000
MAX_JS_KEYWORDS=3000
FULL_PAGE_TEXT_LIMIT=200000

# === Scraper Configuration ===
# Максимальна кількість одночасних запитів
MAX_CONCURRENT_REQUESTS=2
# Затримка між запитами до ЄДРСР (ms)
REQUEST_DELAY_MS=1000
REQUEST_DELAY_JITTER_MS=250
REQUEST_DELAY_ON_RATE_LIMIT_MS=5000
ADAPTIVE_REQUEST_DELAY=true
# Таймаути
CASE_TIMEOUT_MS=30000
FETCH_CASE_TIMEOUT_MS=30000
OVERALL_REQUEST_TIMEOUT_MS=60000
GOT_REQUEST_TIMEOUT_MS=45000
GOT_RETRY_LIMIT=2
GOT_RETRY_BACKOFF_MS=1500
MAX_RETRIES=3
# Blacklisted case IDs (comma-separated)
BLACKLISTED_CASE_IDS=
SCRAPER_SKIP_CACHE=false
EDRSR_FIXTURES_DIR=

# === API Limits ===
MAX_LINKS_PER_REQUEST=300
MAX_URL_LENGTH=2048
MAX_PROMPT_LENGTH=4000
MAX_PROMPT_NAME_LENGTH=120
MAX_COOKIE_LENGTH=4096
MAX_CHAT_MESSAGE_LENGTH=4000
MAX_PROMPTS_IMPORT=200

# === Database (Supabase PostgreSQL) ===
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-east-2.pooler.supabase.com:6543/postgres"
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# PostgreSQL connection tuning (recommended for Supabase/pgBouncer)
PGSSL=false
PGSSLMODE=require
PG_SSL_REJECT_UNAUTHORIZED=false
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000
PG_MAX_USES=7500

# === Worker Configuration ===
# Максимальна тривалість job (ms)
MAX_JOB_DURATION_MS=1500000
# Максимальний час без прогресу до примусового завершення (ms)
MAX_STALL_DURATION_MS=1200000
# Автоприбрання/термінація
ENABLE_WORKER_CLEANUP=true
WORKER_CLEANUP_INTERVAL_MS=300000
ENABLE_WORKER_AUTO_TERMINATE=true
WORKER_MAX_LIFETIME_MS=7200000
# Healthcheck
WORKER_HEALTHCHECK_INTERVAL_MS=600000
WORKER_HEALTHCHECK_AFTER_MS=1200000
# Recovery
ENABLE_PERIODIC_RECOVERY=true
RECOVERY_INTERVAL_MS=900000

# === Chat Session Limits (in-memory) ===
# Максимальна кількість одночасних chat сесій в пам'яті
CHAT_MAX_SESSIONS=5
# TTL для неактивних сесій (ms)
CHAT_TTL_MS=900000
# Інтервал очистки сесій (ms)
CHAT_CLEANUP_INTERVAL_MS=300000
ENABLE_CHAT_CLEANUP=true

# === Cache Configuration ===
# Максимальна кількість закешованих справ
CACHE_MAX_PARSED_CASES=1000
# Інтервал очистки кешу (ms)
CACHE_CLEANUP_INTERVAL_MS=900000
# TTL для тимчасових помилок кешу (ms)
CACHE_TEMP_ERROR_TTL_MS=3600000
# Statement timeout for cache queries (ms)
CACHE_STATEMENT_TIMEOUT_MS=60000
ENABLE_CACHE_CLEANUP=true

# === Prompt Audit ===
# Retention for prompt audit log (days)
PROMPT_AUDIT_RETENTION_DAYS=90
# Cleanup interval (ms)
PROMPT_AUDIT_CLEANUP_INTERVAL_MS=21600000

# === Health ===
HEALTH_FULL_TTL_MS=15000

# === Render-specific ===
RENDER=false
RENDER_EXTERNAL_URL=
RENDER_SERVICE_NAME=
