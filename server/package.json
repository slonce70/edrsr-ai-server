{
  "name": "edrsr-gemini-backend",
  "version": "1.0.4",
  "type": "module",
  "description": "Backend server for ЄДРСР AI analysis with Gemini",
  "main": "index.js",
  "scripts": {
    "dev": "node index.js",
    "start": "node --max-old-space-size=2048 --expose-gc --trace-warnings --enable-source-maps index.js",
    "start:optimized": "node start-optimized.js",
    "start:basic": "node index.js",
    "start:monitor": "ENABLE_MEMORY_MONITORING=true node start-optimized.js",
    "admin:create": "node scripts/create-admin.js",
    "admin:grant": "node scripts/create-admin-simple.js",
    "transfer:jobs": "node scripts/transfer-jobs-to-user.js"
  },
  "dependencies": {
    "@google/genai": "^1.31.0",
    "@supabase/supabase-js": "^2.45.4",
    "cheerio": "^1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "edrsr-ai-monorepo": "file:..",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "got": "^14.4.2",
    "iconv-lite": "^0.6.3",
    "p-limit": "^5.0.0",
    "pg": "^8.16.3",
    "uuid": "^9.0.1",
    "ws": "^8.18.0"
  },
  "keywords": [
    "edrsr",
    "gemini",
    "ai",
    "court",
    "decisions"
  ],
  "author": "EDRSR AI Team",
  "license": "MIT"
}
