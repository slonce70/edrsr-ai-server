{
  "name": "edrsr-ai-monorepo",
  "version": "2.0.3",
  "type": "module",
  "private": true,
  "description": "Project root for EDRSR AI Server and Extension",
  "scripts": {
    "dev": "npm --prefix server run dev",
    "start:gc": "node server/start-with-gc.js",
    "test:memory": "node --expose-gc server/scripts/memory-load-test.js",
    "build:extension": "node scripts/build-extension.js",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:lint": "npm --prefix web run lint",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:server": "npm --prefix server run lint",
    "format:server": "npm --prefix server run format",
    "quality:check": "npm run lint && npm run format:check",
    "quality:fix": "npm run lint:fix && npm run format",
    "apply:rls": "node scripts/apply-rls.js",
    "admin:create": "node server/scripts/create-admin.js",
    "admin:grant": "node server/scripts/create-admin-simple.js",
    "test:selfcheck": "node scripts/selfcheck.js"
  },
  "bin": {},
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "archiver": "^7.0.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "fs-extra": "^11.2.0",
    "pg": "^8.16.3",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "@google/genai": "^1.31.0",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^26.1.0",
    "turndown": "^7.2.2"
  }
}
