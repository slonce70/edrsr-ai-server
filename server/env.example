# Gemini API Key - отримайте безплатно у Google AI Studio: https://ai.google.dev
# Один ключ (backward compatible):
GEMINI_API_KEY=

# АБО кілька ключів через кому для збільшення лімітів (пріоритет над GEMINI_API_KEY):
# 10 ключів = 10x ліміт (150 RPM замість 15 RPM на безкоштовному тарифі)
GEMINI_API_KEYS=

# Server Configuration
PORT=4000
NODE_ENV=development

# Rate Limiting & Performance (Tuned for Speed)
MAX_CONCURRENT_REQUESTS=1
REQUEST_DELAY_MS=1000
CASE_TIMEOUT_MS=30000
OVERALL_REQUEST_TIMEOUT_MS=60000
GOT_REQUEST_TIMEOUT_MS=45000

# Gemini Settings
MODEL_NAME=gemini-2.5-flash
TEMPERATURE=0.3
TOP_K=40
TOP_P=0.8
MAX_TOKENS=65536
MAX_TOKENS_PER_BATCH=60000
FALLBACK_MODEL_NAME=gemini-2.5-flash

# Database Supabase
DATABASE_URL="postgresql://postgres...."
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Optional Postgres client tuning (recommended for Supabase/pgBouncer)
# Set PGSSL=true or PGSSLMODE=require to enable SSL
PGSSL=false
PGSSLMODE=
# Pool sizing and timeouts
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000
PG_MAX_USES=7500

# BATCH ANALYSIS (Tuned for Memory Optimization)
OPTIMAL_BATCH_SIZE=10
BATCH_THRESHOLD=15
BATCH_DELAY=1000
# Batch size для завантаження справ (зменшено з 25 для економії памʼяті)
BATCH_SIZE=10
# Максимальна кількість паралельних batch-ів AI аналізу
MAX_CONCURRENT_BATCHES=2

# Memory Management (для Render.com free tier 512MB)
MEMORY_WARNING_MB=200
MAX_MEMORY_MB=400

# Worker timeouts (ms)
# Максимальная длительность задания и время без прогресса до принудительного завершения
MAX_JOB_DURATION_MS=1500000
MAX_STALL_DURATION_MS=1200000

# Scraper safety limits
# Max HTML size to parse (bytes)
MAX_HTML_BYTES=3500000
# Treat pages with too many scripts/long lines as bad pages and skip
MAX_SCRIPT_TAGS=200
MAX_HTML_LINE_LENGTH=200000
# JS density guard (occurrences of "function(")
MAX_JS_KEYWORDS=1500

# Memory guard for batch downloading (MB)
MEMORY_LIMIT_MB=500

# Logging
LOG_LEVEL=info

# Chat Session Limits (in-memory)
# Maximum number of simultaneous chat sessions kept in memory
CHAT_MAX_SESSIONS=100
# Time to live for idle chat sessions in milliseconds (default 4 hours)
CHAT_TTL_MS=14400000
# Cleanup interval for pruning expired/LRU sessions in milliseconds (default 5 minutes)
CHAT_CLEANUP_INTERVAL_MS=300000

# Cache cleanup (parsed_cases)
# Keep at most this many most-recent cached cases
CACHE_MAX_PARSED_CASES=1000
# Run cleanup every N ms (default 15 minutes)
CACHE_CLEANUP_INTERVAL_MS=900000
